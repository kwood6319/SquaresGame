<div class="game-layout" data-controller="turn dice">
  <%# Sidebar %>
  <aside class="game-sidebar">
    <%# Active Team — now the hero of the sidebar %>
    <div class="sidebar-section">
      <span class="sidebar-label">Now Playing</span>
      <p class="current-team-name" style="color: <%= @current_team&.colour %>;">
        <%= @current_team&.name %>
      </p>
      <div class="current-team-dot" style="background-color: <%= @current_team&.colour %>;"></div>
    </div>
    <%# Teams %>
    <div class="sidebar-section">
      <span class="sidebar-label">Teams</span>
      <ul class="team-list">
        <% @teams.each do |team| %>
          <li class="team-item <%= 'team-item--active' if team == @current_team %>">
            <span class="team-dot" style="background-color: <%= team.colour %>;"></span>
            <span class="team-name"><%= team.name %></span>
            <span class="team-position text-muted">
              <% if team.on_board %>
                Square <%= team.position + 1 %>
              <% else %>
                Off board
              <% end %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
    <%# Dice %>
    <div class="sidebar-section" data-controller="dice">
      <span class="sidebar-label">Dice</span>
      <div class="d-flex align-items-center gap-3">
        <button class="btn-roll" data-action="click->dice#roll">Roll</button>
        <span class="dice-result" data-dice-target="result">—</span>
      </div>
    </div>
    <%# End Game %>
    <div class="sidebar-section sidebar-section--danger">
      <%= button_to "End Game", @game, method: :delete,
        class: "btn-end-game",
        data: { turbo_confirm: "Are you sure you want to end this game?" } %>
    </div>
  </aside>
  <%# Board %>
  <main class="board-wrap">
    <div class="board" style="--cols: <%= @game.grid_x %>; --rows: <%= @game.grid_y %>;">
      <% visited = @game.visited_squares || [] %>
      <% @total_squares.times do |i| %>
        <%
          teams_here = @teams.select { |t| t.on_board && t.position == i }
          is_goal    = i == @game.goal_square
          is_visited = visited.include?(i)
        %>
        <div class="square
              <%= 'square--visited' if is_visited %>"
              data-index="<%= i %>"
       <%= 'data-action=click->turn#select' unless is_visited %>>
          <span class="square-number"><%= i + 1 %></span>
          <div class="square-teams">
            <% teams_here.each do |team| %>
              <span class="team-token" style="background-color: <%= team.colour %>;"
                    title="<%= team.name %>"></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <%# Entry point tokens — teams not yet on board %>
    <div class="entry-points">
      <% @teams.reject(&:on_board).each do |team| %>
        <div class="entry-token"
             data-entry="<%= team.entry_point %>"
             style="--team-colour: <%= team.colour %>;">
          <span class="team-token" style="background-color: <%= team.colour %>;"
                title="<%= team.name %>"></span>
          <span class="entry-label"><%= team.name %></span>
        </div>
      <% end %>
    </div>
  </main>
</div>
<%# Instruction Modal %>
<div class="modal-backdrop"
     id="instruction-modal"
     style="display:none;"
     onclick="this.style.display='none'">
  <div class="modal-box" id="instruction-modal-box" onclick="event.stopPropagation()">
    <p class="modal-label">Instruction</p>
    <p class="modal-instruction" id="modal-instruction-text"></p>
    <button class="btn-dismiss"
            onclick="document.getElementById('instruction-modal').style.display='none'">
      Got it
    </button>
  </div>
</div>
<%# Win Modal %>
<div class="modal-backdrop modal-backdrop--locked" id="win-modal" style="display:none;">
  <div class="modal-box">
    <p class="goal-marker-win">🏆</p>
    <p class="modal-label">We have a winner!</p>
    <p class="modal-instruction" id="win-team-name"></p>
    <%= button_to "Play Again", new_game_path, method: :get, class: "btn-dismiss" %>
    <%= button_to "End Game", @game, method: :delete, class: "btn-end-game mt-2" %>
  </div>
</div>
<%# Turn form — hidden, submitted by Stimulus %>
<%= form_with url: game_turns_path(@game), method: :post, id: "turn-form", data: { turbo: "false" } do |f| %>
  <%= hidden_field_tag :square, nil, id: "turn-square" %>
  <%= hidden_field_tag :team_id, @current_team&.id, id: "turn-team-id" %>
  <%= hidden_field_tag :team_color, @current_team&.colour, id: "turn-team-colour" %>
<% end %>
