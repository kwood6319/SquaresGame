<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Squares Game" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Squares Game">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <%= yield %>
    <% if notice %>
      <% if notice.start_with?("WIN:") %>
        <% team_name = notice.sub("WIN:", "") %>
        <script>
          document.getElementById("win-team-name").textContent = "<%= j team_name %> wins!";
          document.getElementById("win-modal").style.display = "flex";
        </script>
      <% else %>
        <script>
          document.getElementById("modal-instruction-text").textContent = "<%= j notice %>";
          document.getElementById("instruction-modal").style.display = "flex";
        </script>
      <% end %>
    <% end %>
  </body>
</html>
